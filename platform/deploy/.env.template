# Copy this file to .env (which is gitignored) and fill in the values.
# Loaded by docker-compose.yml in this directory.

# ---- Required ----

# Anthropic API key — used by the orchestrator, planner, and researcher Claude calls.
# Get from https://console.anthropic.com
ANTHROPIC_API_KEY=

# Postgres password for the local container. Pick anything; only matters inside the compose network.
POSTGRES_PASSWORD=change-me-locally

# ---- Required for document parsing (skills/document-parsing/) ----

# LlamaParse / LlamaCloud API key — used to parse PDFs, DOCX, PPTX, scanned images.
# Get from https://cloud.llamaindex.ai → API Keys
LLAMA_CLOUD_API_KEY=

# ---- Optional ----

# Tavily — web search backend for the researcher when ToolUniverse isn't enough.
# Get from https://tavily.com (free tier ~1000 searches/month)
TAVILY_API_KEY=

# LangSmith — observability for agent traces, token usage, latency.
# Get from https://smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=make-skills
LANGSMITH_TRACING=false

# ---- Service config (defaults are fine) ----

POSTGRES_USER=postgres
POSTGRES_DB=make_skills
API_PORT=8001
UI_PORT=8000

# Constructed DATABASE_URL — leave as-is; compose will substitute the values above.
DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
