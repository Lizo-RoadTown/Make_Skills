# Copy this file to .env (which is gitignored) and fill in the values.
# Loaded by docker-compose.yml in this directory.

# ---- Required ----

# Pillar 0 — selects the auth backend at startup.
# self_host  (default) — no auth, single tenant. Right for self-host.
# hosted               — JWT-verified per-request tenant. Required when running
#                         alongside the Next.js Auth.js app on Vercel.
PLATFORM_MODE=self_host

# Auth.js shared secret. ONLY required when PLATFORM_MODE=hosted.
# Must byte-match web/.env.local AUTH_SECRET. Generate one:
#   openssl rand -hex 32
# AUTH_SECRET=

# Anthropic API key — used by the orchestrator, planner, and researcher Claude calls.
# Get from https://console.anthropic.com
ANTHROPIC_API_KEY=

# Postgres runs in trust mode (no password needed) since the port isn't exposed to the host.
# If you ever expose port 5432, set a real password here and switch the postgres service back
# to POSTGRES_PASSWORD in docker-compose.yml.
# POSTGRES_PASSWORD=optional-only-if-you-expose-the-port

# ---- Required for document parsing (skills/document-parsing/) ----

# LlamaParse / LlamaCloud API key — used to parse PDFs, DOCX, PPTX, scanned images.
# Get from https://cloud.llamaindex.ai → API Keys
LLAMA_CLOUD_API_KEY=

# ---- Optional ----

# Tavily — web search backend for the researcher when ToolUniverse isn't enough.
# Get from https://tavily.com (free tier ~1000 searches/month)
TAVILY_API_KEY=

# LangSmith — observability for agent traces, token usage, latency.
# Get from https://smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=make-skills
LANGSMITH_TRACING=false

# ---- Model providers (Pillar 1 — pick your creature's brain) ----
# Anthropic is configured above (required for the default agent).
# Add any of these to enable that provider for subagents. Each is
# lazy-loaded — empty values are fine; provider only activates when
# a subagent's deepagents.toml specifies it.

# OpenAI / GPT — https://platform.openai.com → API keys
OPENAI_API_KEY=

# Google Gemini — https://aistudio.google.com → API keys
GOOGLE_API_KEY=

# Hugging Face Inference Providers (free-tier friendly) —
# https://huggingface.co/settings/tokens
HUGGINGFACEHUB_API_TOKEN=

# Together AI — https://api.together.ai → settings
TOGETHER_API_KEY=

# Groq (extremely fast inference) — https://console.groq.com → API keys
GROQ_API_KEY=

# Ollama — local by default. To point at a remote endpoint (Docker Cloud,
# tunneled laptop, VPS), set the URL and an auth header. See the
# "BYO personal Ollama" doc page for full setup options.
# OLLAMA_BASE_URL=https://your-ollama-endpoint.example.com
# OLLAMA_AUTH_HEADER=Bearer your-long-random-secret

# ---- Service config (defaults are fine) ----

POSTGRES_USER=postgres
POSTGRES_DB=make_skills
API_PORT=8001
GRAFANA_PORT=3001

# Constructed DATABASE_URL — leave as-is; compose substitutes POSTGRES_USER and POSTGRES_DB.
DATABASE_URL=postgresql://${POSTGRES_USER}@postgres:5432/${POSTGRES_DB}
