# Local dev — points the chat UI at the FastAPI agent running in Docker.
NEXT_PUBLIC_AGENT_URL=http://localhost:8001

# Grafana — observability dashboards (iframed at /dashboard).
NEXT_PUBLIC_GRAFANA_URL=http://localhost:3001

# Production — set these in Vercel project settings to your public URLs.
# NEXT_PUBLIC_AGENT_URL=https://agent.your-domain.com
# NEXT_PUBLIC_GRAFANA_URL=https://grafana.your-domain.com
