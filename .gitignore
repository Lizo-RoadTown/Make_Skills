.DS_Store
Thumbs.db
*.swp
*.swo
# VS Code: ignore personal preferences, but commit workspace-shared config
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/tasks.json
!.vscode/launch.json
.idea/
__pycache__/
*.py[cod]
.env
*.env
!.env.template
node_modules/

# Render CLI binary — local-only, downloaded per-machine.
render.exe
render

# Upstream skill libraries — cloned locally, not vendored.
# Re-create with: scripts/sync-upstream.sh
skills/_upstream/

# Eval harnesses — cloned on demand under platform/eval/, never vendored.
# E.g. deep_research_bench: clone into platform/eval/deep_research_bench/ when scoring a run.
platform/eval/

# Architectural reference clones — read-only patterns, not runtime deps.
# Refresh with scripts/sync-references.sh
platform/_reference/

# Heavy reference PDFs the user keeps locally — not vendored.
# (Originally `Docs/` matched case-insensitively on Windows and hid the
#  documentation tree at docs/; now scoped to PDFs in a sub-folder.)
docs/_pdfs/
*.pdf

# ROADMAP.md is a per-tenant artifact — each user's roadmap is theirs.
# The roadmap-maintenance skill writes here; gitignored so the platform
# repo doesn't carry one user's status tracking. Public project planning
# (the "what does Make_Skills aim to be" doc, separate from "where is
# Liz right now") will live elsewhere — TBD per the open-source plan.
/ROADMAP.md
